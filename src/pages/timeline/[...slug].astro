---
import { getCollection, render } from "astro:content";
import MinimalLayout from "../../layouts/MinimalLayout.astro";
import "../../style/post.css";

export async function getStaticPaths() {
    const posts = await getCollection("log");
    return posts.map((entry) => ({
        params: { slug: entry.id },
        props: { entry },
    }));
}

import { formatDateLong } from "../../utils/formatDate";

const { entry } = Astro.props;
const redirectTo = entry.data.redirectTo;
const redirectHref = redirectTo ? new URL(redirectTo, Astro.site).href : "";
const rendered = redirectTo ? null : await render(entry);
const Content = rendered?.Content;

// Only ship the KaTeX stylesheet when the post actually contains math.
const hasMath = !redirectTo && (entry.body === undefined ? true : /\$/.test(entry.body));
---

{
    redirectTo ? (
        <html lang="en">
            <head>
                <meta charset="utf-8" />
                <meta name="robots" content="noindex, follow" />
                <meta http-equiv="refresh" content={`0; url=${redirectTo}`} />
                <link rel="canonical" href={redirectHref} />
                <title>{entry.data.title} | Audiofool</title>
            </head>
            <body>
                <p>
                    This timeline entry has moved to{" "}
                    <a href={redirectTo}>{redirectTo}</a>.
                </p>
            </body>
        </html>
    ) : (
        <MinimalLayout
            title={`${entry.data.title} | Timeline`}
            description={entry.data.description}
            ogType="article"
            math={hasMath}
            datePublished={entry.data.pubDate}
        >
            <div class="p-6 md:p-12 flex justify-center" transition:animate="fade">
                <article class="max-w-4xl w-full anime-fade-in-up">
                    <!-- Timeline Header -->
                    <header
                        class="mb-10 text-center border-b border-[var(--border-main)] pb-8"
                    >
                        <time
                            class="font-mono text-xs text-[var(--text-muted)] uppercase tracking-widest mb-4 block"
                        >
                            {formatDateLong(entry.data.pubDate)}
                        </time>
                        <h1 class="text-3xl md:text-5xl font-bold font-heading mb-6">
                            {entry.data.title}
                        </h1>

                        <div class="flex flex-wrap justify-center gap-2">
                            {entry.data.tags.map((tag) => (
                                <span class="text-xs font-mono text-[var(--text-muted)] before:content-['#']">
                                    {tag}
                                </span>
                            ))}
                        </div>
                    </header>

                    <!-- Content -->
                    <div class="post-content">
                        {Content && <Content />}
                    </div>
                </article>
            </div>
        </MinimalLayout>
    )
}
