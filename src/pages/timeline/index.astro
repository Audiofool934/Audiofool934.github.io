---
import MinimalLayout from "../../layouts/MinimalLayout.astro";
import { getCollection } from "astro:content";
import { formatDateCompact } from "../../utils/formatDate";
import { getPostType } from "../../utils/postType";

const posts = await getCollection("log");

const sortedPosts = posts.sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const typeLabels: Record<string, string> = {
    note: "Notes",
    post: "Posts",
    music: "Music",
    photo: "Photos",
    project: "Projects",
    site: "Site Changes",
};

const filterOrder = ["note", "post", "music", "photo", "project", "site"];
const typeCounts = new Map<string, number>();
for (const post of sortedPosts) {
    const type = getPostType(post);
    typeCounts.set(type, (typeCounts.get(type) || 0) + 1);
}
const filters = filterOrder
    .filter((type) => typeCounts.has(type))
    .map((type) => ({ type, label: typeLabels[type], count: typeCounts.get(type)! }));
---

<MinimalLayout
    title="Timeline | Audiofool"
    description="A chronological record of notes, posts, music, photos, and site changes."
>
    <div class="p-6 md:p-12" transition:animate="fade">
        <header class="mb-8">
            <h1 class="text-4xl font-bold font-heading mb-2">Timeline</h1>
            <p
                class="font-mono text-sm text-[var(--text-muted)] tracking-wider uppercase"
            >
                A chronological record
            </p>
        </header>

        <div
            class="flex flex-wrap gap-3 pb-4 mb-8 border-b border-[var(--border-main)] text-sm font-mono"
        >
            <button
                type="button"
                data-type="all"
                aria-pressed="true"
                class="timeline-filter active whitespace-nowrap transition-colors"
            >
                [ All <span class="text-[var(--text-faint)]">{sortedPosts.length}</span> ]
            </button>
            {
                filters.map(({ type, label, count }) => (
                    <button
                        type="button"
                        data-type={type}
                        aria-pressed="false"
                        class="timeline-filter whitespace-nowrap transition-colors"
                    >
                        [ {label} <span class="text-[var(--text-faint)]">{count}</span> ]
                    </button>
                ))
            }
        </div>

        <div class="max-w-4xl border-l border-[var(--border-main)] pl-5 md:pl-8">
            {
                sortedPosts.map((post) => {
                    const type = getPostType(post);
                    return (
                        <a
                            href={`/timeline/${post.id}/`}
                            class="timeline-entry group relative block pb-8 text-[var(--text-muted)] hover:text-[var(--text-main)] transition-colors"
                            data-type={type}
                        >
                            <span class="absolute -left-[1.65rem] md:-left-[2.15rem] top-1 h-2 w-2 rounded-full bg-[var(--bg-body)] border border-[var(--text-main)] group-hover:bg-[var(--text-main)] transition-colors" />

                            <div class="grid gap-1 md:grid-cols-[8rem_5rem_minmax(0,1fr)] md:gap-4 md:items-baseline font-mono text-sm">
                                <time class="text-xs uppercase tracking-wider text-[var(--text-faint)] transition-opacity">
                                    {formatDateCompact(post.data.pubDate)}
                                </time>

                                <span class="text-[10px] uppercase tracking-wider text-[var(--text-faint)] transition-opacity">
                                    {type}
                                </span>

                                <div class="min-w-0">
                                    <h2 class="font-sans text-base font-semibold text-[var(--text-main)] group-hover:underline decoration-1 underline-offset-4">
                                        {post.data.title}
                                    </h2>
                                    {post.data.description && (
                                        <p class="mt-1 font-sans text-sm leading-relaxed text-[var(--text-faint)]">
                                            {post.data.description}
                                        </p>
                                    )}
                                </div>
                            </div>
                        </a>
                    );
                })
            }

            <div
                id="timeline-empty"
                class="hidden py-12 text-[var(--text-muted)] font-mono text-sm"
            >
                No entries in this lane yet.
            </div>

            {
                sortedPosts.length === 0 && (
                    <div class="py-12 text-[var(--text-muted)]">
                        No timeline entries yet.
                    </div>
                )
            }
        </div>
    </div>
</MinimalLayout>

<style>
    .timeline-filter {
        color: var(--text-muted);
    }
    .timeline-filter:hover {
        color: var(--text-main);
    }
    .timeline-filter.active {
        color: var(--text-main);
        text-decoration: underline;
        text-underline-offset: 4px;
        text-decoration-thickness: 1px;
    }
</style>

<script is:inline>
    (function () {
        let cleanupFn = null;

        document.addEventListener("astro:page-load", () => {
            if (cleanupFn) {
                cleanupFn();
                cleanupFn = null;
            }

            const filters = document.querySelectorAll(".timeline-filter");
            const entries = document.querySelectorAll(".timeline-entry");
            const empty = document.getElementById("timeline-empty");
            if (!filters.length) return;

            function applyFilter(filter) {
                filters.forEach((item) => {
                    item.classList.remove("active");
                    item.setAttribute("aria-pressed", "false");
                });
                var btn = document.querySelector(
                    '.timeline-filter[data-type="' + filter + '"]',
                );
                if (btn) {
                    btn.classList.add("active");
                    btn.setAttribute("aria-pressed", "true");
                }

                var visible = 0;
                entries.forEach((entry) => {
                    var show = filter === "all" || entry.dataset.type === filter;
                    entry.style.display = show ? "" : "none";
                    if (show) visible += 1;
                });

                if (empty) empty.classList.toggle("hidden", visible > 0);
            }

            function onClick(e) {
                applyFilter(e.currentTarget.dataset.type);
            }

            filters.forEach((filter) => {
                filter.addEventListener("click", onClick);
            });

            var urlType = new URLSearchParams(window.location.search).get("type");
            if (urlType) applyFilter(urlType.toLowerCase());

            cleanupFn = function () {
                filters.forEach((filter) =>
                    filter.removeEventListener("click", onClick),
                );
            };
        });
    })();
</script>
