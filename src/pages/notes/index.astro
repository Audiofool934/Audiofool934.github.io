---
import MinimalLayout from "../../layouts/MinimalLayout.astro";
import { getCollection } from "astro:content";

const wikiEntries = await getCollection("wiki");

// Sort by updatedDate desc (fallback to pubDate)
const sorted = [...wikiEntries].sort((a, b) => {
    const dateA = (
        a.data.updatedDate ||
        a.data.pubDate ||
        new Date(0)
    ).valueOf();
    const dateB = (
        b.data.updatedDate ||
        b.data.pubDate ||
        new Date(0)
    ).valueOf();
    return dateB - dateA;
});

// Entry lookup
const entryMap = new Map(sorted.map((e) => [e.id, e]));

// Bidirectional connection count
const connections = new Map<string, Set<string>>();
for (const entry of sorted) {
    if (!connections.has(entry.id)) connections.set(entry.id, new Set());
    for (const id of [
        ...(entry.data.parents || []),
        ...(entry.data.related || []),
    ]) {
        if (!entryMap.has(id)) continue;
        connections.get(entry.id)!.add(id);
        if (!connections.has(id)) connections.set(id, new Set());
        connections.get(id)!.add(entry.id);
    }
}

const kindOrder = ["Concept", "Method", "Model", "Essay", "Reference"];
const kindCounts = new Map<string, number>();
for (const entry of sorted) {
    kindCounts.set(entry.data.kind, (kindCounts.get(entry.data.kind) || 0) + 1);
}
const filters = kindOrder
    .filter((kind) => kindCounts.has(kind))
    .map((kind) => ({ key: kind.toLowerCase(), label: kind, count: kindCounts.get(kind)! }));

function getDate(entry: (typeof sorted)[0]) {
    const d = entry.data.updatedDate || entry.data.pubDate;
    return d ? d.toISOString().split("T")[0] : "";
}

function getConnectionCount(id: string) {
    return connections.get(id)?.size || 0;
}
---

<MinimalLayout title="Notes | Audiofool" description="Personal notes and working ideas">
    <div class="p-6 md:p-12 mb-20" transition:animate="fade">
        <header class="mb-8">
            <h1 class="text-4xl font-bold font-heading mb-2">Notes</h1>
            <p
                class="font-mono text-sm text-[var(--text-muted)] tracking-wider uppercase"
            >
                {sorted.length} entries · personal notes and working ideas
            </p>
        </header>

        <!-- Kind Filters -->
        <div
            class="flex flex-wrap gap-3 pb-4 mb-8 border-b border-[var(--border-main)] text-sm font-mono"
        >
            <button
                data-kind="all"
                class="note-kind active whitespace-nowrap transition-colors"
            >
                [ All <span class="text-[var(--text-faint)]">{sorted.length}</span> ]
            </button>
            {
                filters.map(({ key, label, count }) => (
                    <button
                        data-kind={key}
                        class="note-kind whitespace-nowrap transition-colors"
                    >
                        [ {label}{" "}
                        <span class="text-[var(--text-faint)]">{count}</span> ]
                    </button>
                ))
            }
        </div>

        <!-- Entry List -->
        <div id="note-entries">
            {
                sorted.map((entry) => {
                    const connCount = getConnectionCount(entry.id);
                    return (
                        <a
                            href={`/notes/${entry.id}/`}
                            class="note-entry group block py-3.5 border-b border-[var(--border-subtle)] hover:border-[var(--border-main)] transition-colors"
                            data-kind={entry.data.kind.toLowerCase()}
                        >
                            <div class="grid grid-cols-[5.5rem_minmax(0,1fr)_auto] gap-4 items-start">
                                <span class="font-mono text-[10px] uppercase tracking-wider text-[var(--text-faint)] pt-1">
                                    {entry.data.kind}
                                </span>
                                <div class="min-w-0">
                                    <h2 class="font-bold text-[15px] group-hover:underline decoration-1 underline-offset-4">
                                        {entry.data.title}
                                    </h2>
                                    <div class="flex flex-wrap items-center gap-x-2 gap-y-1 mt-1.5">
                                        {entry.data.tags.map((tag) => (
                                            <span class="font-mono text-[10px] text-[var(--text-faint)]">
                                                {tag.toLowerCase()}
                                            </span>
                                        ))}
                                        {connCount > 0 && (
                                            <span class="font-mono text-[10px] text-[var(--text-faint)] ml-1">
                                                · {connCount}↔
                                            </span>
                                        )}
                                    </div>
                                </div>
                                <span class="flex-shrink-0 font-mono text-[11px] text-[var(--text-faint)] pt-0.5">
                                    {getDate(entry)}
                                </span>
                            </div>
                        </a>
                    );
                })
            }
        </div>

        {
            sorted.length === 0 && (
                <div class="py-16 text-center text-[var(--text-muted)]">
                    No entries yet.
                </div>
            )
        }
    </div>
</MinimalLayout>

<style>
    .note-kind {
        color: var(--text-muted);
    }
    .note-kind:hover {
        color: var(--text-main);
    }
    .note-kind.active {
        color: var(--text-main);
        text-decoration: underline;
        text-underline-offset: 4px;
        text-decoration-thickness: 1px;
    }
    @media (max-width: 640px) {
        .note-entry > div {
            grid-template-columns: 1fr auto;
        }
        .note-entry > div > span:first-child {
            grid-column: 1 / -1;
            padding-top: 0;
        }
    }
</style>

<script is:inline>
    (function () {
        let cleanupFn = null;

        document.addEventListener("astro:page-load", () => {
            if (cleanupFn) {
                cleanupFn();
                cleanupFn = null;
            }

            const filters = document.querySelectorAll(".note-kind");
            const entries = document.querySelectorAll(".note-entry");
            if (!filters.length) return;

            function applyFilter(filter) {
                filters.forEach((t) => t.classList.remove("active"));
                var btn = document.querySelector(
                    '.note-kind[data-kind="' + filter + '"]',
                );
                if (btn) btn.classList.add("active");

                entries.forEach((entry) => {
                    entry.style.display =
                        filter === "all" || entry.dataset.kind === filter
                            ? ""
                            : "none";
                });
            }

            function onClick(e) {
                applyFilter(e.currentTarget.dataset.kind);
            }

            filters.forEach((tab) => {
                tab.addEventListener("click", onClick);
            });

            // Auto-filter from URL query
            var urlKind = new URLSearchParams(window.location.search).get("kind");
            if (urlKind) applyFilter(urlKind.toLowerCase());

            cleanupFn = function () {
                filters.forEach((t) => t.removeEventListener("click", onClick));
            };
        });
    })();
</script>
