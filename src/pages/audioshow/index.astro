---
import MinimalLayout from "../../layouts/MinimalLayout.astro";
import { sortEpisodesDesc } from "../../utils/parseAudioshow";
import { loadAllEpisodes } from "../../utils/loadEpisodes";

const allEpisodes = loadAllEpisodes();

// Sort by episode number descending and get recent 10
const sortedEpisodes = sortEpisodesDesc(allEpisodes);
const recentEpisodes = sortedEpisodes.slice(0, 10);

// Placeholder image for episodes without artwork
const placeholderImage = "/images/placeholder-album.svg";

---

<MinimalLayout
    title="AudioShow | Audiofool"
    description="The Great Gig in the Sky"
>
    <div class="p-6 md:p-12 mb-20" transition:animate="fade">
        <!-- Header -->
        <div class="mb-8">
            <h1 class="text-4xl font-bold font-heading mb-2">AudioShow</h1>
            <p class="font-mono text-sm text-[var(--text-muted)] tracking-wider uppercase">
                The Great Gig in the Sky
            </p>
        </div>

        <!-- Navigation -->
        <div class="flex gap-4 mb-10 text-sm font-mono border-b border-[var(--border-main)] pb-4">
            <span class="text-[var(--text-main)] underline decoration-1 underline-offset-4">
                [ Recent ]
            </span>
            <a
                href="/audioshow/archive/"
                class="text-[var(--text-muted)] hover:text-[var(--text-main)] transition-colors"
            >
                [ Archive ]
            </a>
        </div>

        <!-- Recent Episodes - Horizontal Scroll -->
        <section class="relative">
            <!-- Scrollable Container -->
            <div class="audioshow-carousel flex gap-4 md:gap-6 overflow-x-auto pb-6 md:pb-8 pt-4 scrollbar-hide">
                <!-- Edge spacers let the first/last card settle cleanly in the viewing lane. -->
                <div class="carousel-edge-spacer" aria-hidden="true"></div>
                
                {recentEpisodes.map((ep) => (
                    <div
                        class="ep-card flex-shrink-0 border border-[var(--border-main)] bg-[var(--bg-body)] transition-all relative"
                    >
                        <!-- Album Artwork - click to play -->
                        <div
                            class="ep-artwork relative aspect-square border-b border-[var(--border-main)] overflow-hidden bg-neutral-100 dark:bg-neutral-900 cursor-pointer"
                            data-track={(ep.appleMusicUrl || ep.audioPreviewUrl) ? JSON.stringify({
                                type: ep.audioPreviewUrl ? 'local' : 'apple',
                                url: ep.audioPreviewUrl || ep.appleMusicUrl,
                                title: ep.songTitle,
                                artist: ep.artist,
                                artwork: ep.imageUrl || placeholderImage
                            }) : undefined}
                        >
                            <img 
                                src={ep.imageUrl || placeholderImage}
                                alt={ep.coverAlt || `${ep.songTitle} - ${ep.artist}`}
                                class="ep-cover-image w-full h-full object-cover transition-transform duration-500"
                                loading="lazy"
                                onerror={`this.src='${placeholderImage}'`}
                            />
                            <!-- Play Overlay -->
                            {(ep.appleMusicUrl || ep.audioPreviewUrl) && (
                                <div class="ep-play-overlay absolute inset-0 bg-black/40 opacity-0 transition-opacity flex items-center justify-center">
                                    <span class="text-white text-4xl">▶</span>
                                </div>
                            )}
                        </div>

                        <!-- Card Content - Fixed height, scrollable -->
                        <div class="ep-content overflow-y-auto overscroll-contain text-center">
                            <!-- Quote -->
                            <p class="ep-quote italic text-[var(--text-muted)] whitespace-pre-line" set:html={`"${ep.lyricExcerpt.replace(/\n/g, '<br/>')}"`}>
                            </p>

                            <!-- Song Info -->
                            <h3 class="ep-title font-bold leading-tight">
                                {ep.songTitle}
                            </h3>
                            <p class="ep-artist text-[var(--text-muted)]">
                                {ep.artist}
                            </p>

                            <!-- Album & Year -->
                            <div class="ep-meta font-mono text-[var(--text-muted)]">
                                <span>{ep.album}</span>
                                <span class="mx-1">•</span>
                                <span>{ep.year}</span>
                            </div>

                            <!-- Episode Number -->
                            <div class="ep-number font-mono text-[var(--text-muted)]">
                                #{ep.number}
                            </div>
                        </div>
                    </div>
                ))}
                
                <!-- Right Spacer -->
                <div class="carousel-edge-spacer" aria-hidden="true"></div>
            </div>
        </section>

        <!-- Empty State -->
        {recentEpisodes.length === 0 && (
            <div class="py-16 text-center text-[var(--text-muted)]">
                <p class="text-4xl mb-4">📻</p>
                <p>No episodes found. The show hasn't started yet.</p>
            </div>
        )}

        <!-- Scroll Navigation (desktop only) -->
        <div class="hidden md:flex items-center justify-center gap-6 mt-8" id="scroll-nav">
            <button id="scroll-left" class="text-[var(--text-muted)] hover:text-[var(--text-main)] transition-colors font-mono text-sm" aria-label="Scroll left">
                ← prev
            </button>
            <button id="scroll-right" class="text-[var(--text-muted)] hover:text-[var(--text-main)] transition-colors font-mono text-sm" aria-label="Scroll right">
                next →
            </button>
        </div>

        <!-- Stats -->
        <div class="mt-8 pt-8 border-t border-[var(--border-main)] flex items-center justify-between text-sm font-mono text-[var(--text-muted)]">
            <span>{allEpisodes.length} episodes total</span>
            <a 
                href="/audioshow/archive/"
                class="hover:text-[var(--text-main)] transition-colors"
            >
                View full archive →
            </a>
        </div>
    </div>
</MinimalLayout>

<style>
    .audioshow-carousel {
        --ep-card-width: 420px;
        --ep-card-gap: 1.5rem;
        scroll-snap-type: x mandatory;
        scroll-padding-inline: max(1.5rem, calc((100% - var(--ep-card-width)) / 2));
        scroll-behavior: smooth;
        overscroll-behavior-x: contain;
        -webkit-overflow-scrolling: touch;
    }

    .carousel-edge-spacer {
        flex: 0 0 max(1.5rem, calc((100% - var(--ep-card-width)) / 2));
        min-width: 0;
    }

    @media (min-width: 768px) {
        .audioshow-carousel {
            scroll-snap-type: none;
            scroll-padding-inline: 4rem;
        }
        .carousel-edge-spacer {
            flex-basis: 4rem;
        }
        .ep-card {
            scroll-snap-align: start;
        }
    }

    /* Default: large cards (vh > 1100px) */
    .ep-card { width: var(--ep-card-width); scroll-snap-align: center; scroll-snap-stop: always; }

    .ep-play-overlay {
        pointer-events: none;
    }

    /* Keep hover cinematic on desktop, but avoid sticky :hover states after taps on touch screens. */
    @media (hover: hover) and (pointer: fine) {
        .ep-card:hover {
            border-color: var(--text-main);
            box-shadow: 0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1);
        }
        .ep-card:hover .ep-cover-image {
            transform: scale(1.05);
        }
        .ep-card:hover .ep-play-overlay {
            opacity: 1;
        }
    }

    /* Touch screens get a short tap response, then return to the clean resting state. */
    @media (hover: none), (pointer: coarse) {
        .ep-card:hover {
            border-color: var(--border-main);
            box-shadow: none;
        }
        .ep-card:hover .ep-cover-image {
            transform: none;
        }
        .ep-card:hover .ep-play-overlay {
            opacity: 0;
        }
        .ep-card.is-tap-feedback {
            animation: ep-tap-card 260ms ease-out;
        }
        .ep-card.is-tap-feedback .ep-cover-image {
            transform: scale(0.985);
        }
        .ep-card.is-tap-feedback .ep-play-overlay {
            opacity: 1;
        }
    }

    @keyframes ep-tap-card {
        0% {
            border-color: var(--border-main);
            box-shadow: none;
        }
        35% {
            border-color: var(--text-main);
            box-shadow: 0 8px 18px -8px rgb(0 0 0 / 0.35);
        }
        100% {
            border-color: var(--border-main);
            box-shadow: none;
        }
    }

    .ep-content { max-height: 190px; padding: 1rem; touch-action: pan-y; -webkit-overflow-scrolling: touch; }
    .ep-quote { font-size: 0.8rem; margin-bottom: 0.75rem; }
    .ep-title { font-size: 1.125rem; margin-bottom: 0.25rem; }
    .ep-artist { font-size: 0.75rem; margin-bottom: 0.375rem; }
    .ep-meta { font-size: 0.75rem; }
    .ep-number { font-size: 0.7rem; margin-top: 0.5rem; }

    /* Hide scrollbar in text area but keep scrollable */
    .ep-content {
        scrollbar-width: none; /* Firefox */
    }
    .ep-content::-webkit-scrollbar {
        display: none; /* Chrome/Safari/Edge */
    }

    /* Medium: 800px < vh <= 1100px */
    @media (max-height: 1100px) {
        .audioshow-carousel { --ep-card-width: 320px; }
        .ep-content { max-height: 165px; padding: 0.75rem; }
        .ep-quote { font-size: 0.75rem; margin-bottom: 0.5rem; }
        .ep-title { font-size: 1rem; margin-bottom: 0.25rem; }
        .ep-artist { font-size: 0.7rem; margin-bottom: 0.25rem; }
        .ep-meta { font-size: 0.65rem; }
        .ep-number { font-size: 0.6rem; margin-top: 0.375rem; }
    }

    /* Compact: vh <= 800px */
    @media (max-height: 800px) {
        .audioshow-carousel { --ep-card-width: 220px; }
        .ep-content { max-height: 130px; padding: 0.625rem; }
        .ep-quote { font-size: 0.65rem; margin-bottom: 0.375rem; }
        .ep-title { font-size: 0.875rem; margin-bottom: 0.125rem; }
        .ep-artist { font-size: 0.65rem; margin-bottom: 0.125rem; }
        .ep-meta { font-size: 0.6rem; }
        .ep-number { font-size: 0.55rem; margin-top: 0.25rem; }
    }

    /* Phones should size the shelf by viewport width, not just viewport height. */
    @media (max-width: 767px) {
        .audioshow-carousel { --ep-card-width: min(74vw, 280px); }
    }
</style>

<script is:inline>
    document.addEventListener("astro:page-load", () => {
        const hasCoarsePointer = () => window.matchMedia("(hover: none), (pointer: coarse)").matches;
        document.querySelectorAll("[data-track]").forEach((el) => {
            el.addEventListener("click", () => {
                const card = el.closest(".ep-card");
                if (card && hasCoarsePointer()) {
                    card.classList.remove("is-tap-feedback");
                    void card.offsetWidth;
                    card.classList.add("is-tap-feedback");
                    window.setTimeout(() => card.classList.remove("is-tap-feedback"), 280);
                }

                const track = JSON.parse(el.dataset.track);
                window.playTrack(track);
            });
        });

        // Scroll navigation + mobile shelf snapping
        const container = document.querySelector(".audioshow-carousel");
        const leftBtn = document.getElementById("scroll-left");
        const rightBtn = document.getElementById("scroll-right");
        if (container) {
            const cards = () => Array.from(container.querySelectorAll(".ep-card"));
            const isDesktop = () => window.matchMedia("(min-width: 768px)").matches;
            const currentIndex = () => {
                const containerRect = container.getBoundingClientRect();
                const styles = getComputedStyle(container);
                const paddingLeft = parseFloat(styles.scrollPaddingLeft) || 0;
                const targetLine = isDesktop()
                    ? containerRect.left + paddingLeft
                    : containerRect.left + containerRect.width / 2;
                return cards().reduce((best, card, index) => {
                    const rect = card.getBoundingClientRect();
                    const cardLine = isDesktop()
                        ? rect.left
                        : rect.left + rect.width / 2;
                    const distance = Math.abs(cardLine - targetLine);
                    return distance < best.distance ? { index, distance } : best;
                }, { index: 0, distance: Infinity }).index;
            };
            const scrollToCard = (index) => {
                const list = cards();
                const target = list[Math.max(0, Math.min(index, list.length - 1))];
                if (!target) return;

                const containerRect = container.getBoundingClientRect();
                const targetRect = target.getBoundingClientRect();
                const styles = getComputedStyle(container);
                const paddingLeft = parseFloat(styles.scrollPaddingLeft) || 0;
                const targetLeft = targetRect.left - containerRect.left + container.scrollLeft;
                const desiredInset = isDesktop()
                    ? paddingLeft
                    : (container.clientWidth - targetRect.width) / 2;

                container.scrollTo({
                    left: Math.max(0, targetLeft - desiredInset),
                    behavior: "smooth",
                });
            };

            if (leftBtn && rightBtn) {
                leftBtn.addEventListener("click", () => scrollToCard(currentIndex() - 1));
                rightBtn.addEventListener("click", () => scrollToCard(currentIndex() + 1));
            }

            let gesture = null;
            container.addEventListener("pointerdown", (event) => {
                if (isDesktop() || event.pointerType === "mouse") return;
                gesture = {
                    x: event.clientX,
                    y: event.clientY,
                    index: currentIndex(),
                };
            });
            container.addEventListener("pointerup", (event) => {
                if (!gesture || isDesktop() || event.pointerType === "mouse") return;
                const dx = event.clientX - gesture.x;
                const dy = event.clientY - gesture.y;
                const horizontal = Math.abs(dx) > 28 && Math.abs(dx) > Math.abs(dy) * 1.2;
                const target = horizontal
                    ? gesture.index + (dx < 0 ? 1 : -1)
                    : currentIndex();
                gesture = null;
                scrollToCard(target);
            });
            container.addEventListener("pointercancel", () => {
                gesture = null;
            });
        }
    });
</script>
