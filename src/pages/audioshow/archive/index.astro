---
import MinimalLayout from "../../../layouts/MinimalLayout.astro";
import { groupEpisodesByRange } from "../../../utils/parseAudioshow";
import { loadAllEpisodes } from "../../../utils/loadEpisodes";
import { audioImage, audioImageSrcset, imageReferrerPolicy } from "../../../utils/audioImages";

const allEpisodes = loadAllEpisodes();

// Group episodes by ranges of 50
const groupedEpisodes = groupEpisodesByRange(allEpisodes, 50);

// Sort range keys numerically
const sortedRanges = Object.keys(groupedEpisodes).sort((a, b) => {
    const startA = parseInt(a.split('-')[0], 10);
    const startB = parseInt(b.split('-')[0], 10);
    return startA - startB;
});

// Placeholder image
const placeholderImage = "/images/placeholder-album.svg";
---

<MinimalLayout
    title="Archive | AudioShow | Audiofool"
    description="The long shelf of what still answers."
>
    <div class="p-6 md:p-12 mb-20" transition:animate="fade">
        <!-- Header -->
        <div class="mb-8">
            <h1 class="text-4xl font-bold font-heading mb-2">AudioShow Archive</h1>
            <p class="font-mono text-sm text-[var(--text-muted)] tracking-wider">
                The long shelf of what still answers.
            </p>
        </div>

        <!-- Navigation -->
        <div class="flex gap-4 mb-10 text-sm font-mono border-b border-[var(--border-main)] pb-4">
            <a 
                href="/audioshow/"
                class="text-[var(--text-muted)] hover:text-[var(--text-main)] transition-colors"
            >
                [ Recent ]
            </a>
            <a
                href="/audioshow/crates/"
                class="text-[var(--text-muted)] hover:text-[var(--text-main)] transition-colors"
            >
                [ Crates ]
            </a>
            <span class="text-[var(--text-main)] underline decoration-1 underline-offset-4">
                [ Archive ]
            </span>
        </div>

        <!-- Episode Ranges -->
        <div class="space-y-8">
            {sortedRanges.map((range) => (
                <section class="border border-[var(--border-main)]" data-range={range}>
                    <details class="group">
                        <summary class="cursor-pointer p-4 flex items-center justify-between hover:bg-[var(--text-main)]/5 transition-colors">
                            <h2 class="text-lg font-bold font-heading flex items-center gap-3">
                                <span class="text-xs font-mono text-[var(--text-muted)]">
                                    [{groupedEpisodes[range].length}]
                                </span>
                                EP {range}
                            </h2>
                            <div class="flex items-center gap-4">
                                <!-- Toggle All Lyrics Button -->
                                <button 
                                    class="text-xs font-mono text-[var(--text-muted)] hover:text-[var(--text-main)] transition-colors px-2 py-1 border border-[var(--border-main)] hover:bg-[var(--text-main)]/5"
                                    data-toggle-all={range}
                                    onclick={`toggleAllLyrics('${range}'); event.stopPropagation();`}
                                >
                                    [lyrics]
                                </button>
                                <span class="font-mono text-xs text-[var(--text-muted)] group-open:rotate-90 transition-transform">
                                    →
                                </span>
                            </div>
                        </summary>

                        <div class="border-t border-[var(--border-main)]" data-episodes={range}>
                            {groupedEpisodes[range].map((ep) => {
                                const cover = ep.imageUrl || placeholderImage;
                                const artwork = audioImage(cover, 320) || placeholderImage;
                                return (
                                <div class="episode-item border-b border-[var(--border-main)] last:border-b-0" data-ep={ep.number}>
                                    <!-- Main Row -->
                                    <div 
                                        class="group flex items-center gap-4 p-4 hover:bg-[var(--text-main)]/5 transition-colors cursor-pointer"
                                        data-ep-row={ep.number}
                                    >
                                        <!-- Thumbnail -->
                                        <div class="w-12 h-12 flex-shrink-0 border border-[var(--border-main)] overflow-hidden">
                                            <img
                                                src={audioImage(cover, 96) || placeholderImage}
                                                srcset={audioImageSrcset(cover, [96, 192])}
                                                sizes="48px"
                                                alt={ep.songTitle}
                                                width="48"
                                                height="48"
                                                class="w-full h-full object-cover"
                                                loading="lazy"
                                                decoding="async"
                                                referrerpolicy={imageReferrerPolicy(cover)}
                                                onerror={`this.src='${placeholderImage}'`}
                                            />
                                        </div>

                                        <!-- Episode Number -->
                                        <div class="w-12 font-mono text-sm text-[var(--text-faint)] text-right">
                                            #{ep.number}
                                        </div>

                                        <!-- Song Info: Title + Album -->
                                        <div class="flex-1 min-w-0">
                                            <div class="font-bold truncate">
                                                {ep.songTitle}
                                            </div>
                                            <div class="text-xs text-[var(--text-muted)] truncate">
                                                {ep.album} ({ep.year})
                                            </div>
                                        </div>

                                        <!-- Artist on right -->
                                        <div class="hidden md:block text-sm text-[var(--text-muted)] truncate max-w-[200px]">
                                            {ep.artist}
                                        </div>

                                        <!-- Play Button -->
                                        {(ep.appleMusicUrl || ep.audioPreviewUrl) ? (
                                            <button
                                                class="w-8 text-center opacity-50 hover:opacity-100 transition-opacity"
                                                aria-label={`Play ${ep.songTitle} by ${ep.artist}`}
                                                data-play-track={JSON.stringify({
                                                    type: (ep.audioPreviewUrl || ep.appleMusicUrl)?.includes('music.apple.com') ? 'apple' : 'local',
                                                    url: ep.audioPreviewUrl || ep.appleMusicUrl,
                                                    title: ep.songTitle,
                                                    artist: ep.artist,
                                                    artwork
                                                })}
                                            >
                                                <span aria-hidden="true">▶</span>
                                            </button>
                                        ) : (
                                            <div class="w-8" aria-hidden="true"></div>
                                        )}

                                        <!-- Expand Toggle -->
                                        <button
                                            type="button"
                                            class="w-6 text-center text-[var(--text-muted)] lyrics-arrow transition-transform"
                                            data-ep-toggle={ep.number}
                                            aria-label={`Toggle lyrics for ${ep.songTitle}`}
                                            aria-expanded="false"
                                        >
                                            <span aria-hidden="true">↓</span>
                                        </button>
                                    </div>

                                    <!-- Lyrics (Hidden by default) -->
                                    <div class="lyrics-content hidden px-4 pb-4">
                                        <div class="ml-[76px] pl-4 border-l-2 border-[var(--border-main)] space-y-3">
                                            <p class="text-sm italic text-[var(--text-muted)] whitespace-pre-line">
                                                {`"${ep.lyricExcerpt}"`}
                                            </p>
                                            {ep.projectLinks.length > 0 && (
                                                <div class="flex flex-wrap gap-2 pt-1">
                                                    {ep.projectLinks.map((link) => (
                                                        <a
                                                            href={link.url}
                                                            target="_blank"
                                                            rel="noreferrer"
                                                            class="text-xs font-mono border border-[var(--border-main)] px-2 py-1 text-[var(--text-muted)] hover:text-[var(--text-main)] hover:bg-[var(--text-main)]/5 transition-colors"
                                                        >
                                                            {link.label}
                                                        </a>
                                                    ))}
                                                </div>
                                            )}
                                        </div>
                                    </div>
                                </div>
                                );
                            })}
                        </div>
                    </details>
                </section>
            ))}
        </div>

        <!-- Empty State -->
        {allEpisodes.length === 0 && (
            <div class="py-16 text-center text-[var(--text-muted)]">
                <p class="text-4xl mb-4">📻</p>
                <p>No episodes found. The show hasn't started yet.</p>
            </div>
        )}

        <!-- Back Link -->
        <div class="mt-12 pt-8 border-t border-[var(--border-main)]">
            <a 
                href="/audioshow/"
                class="text-sm font-mono text-[var(--text-muted)] hover:text-[var(--text-main)] transition-colors"
            >
                ← Back to Recent
            </a>
        </div>
    </div>
</MinimalLayout>

<script is:inline>
    document.addEventListener("astro:page-load", () => {
        // Toggle a single episode's lyrics (shared by row click + expand button)
        function setEpisodeExpanded(epItem, expanded) {
            const lyricsContent = epItem.querySelector('.lyrics-content');
            const arrow = epItem.querySelector('.lyrics-arrow');
            const toggleBtn = epItem.querySelector('[data-ep-toggle]');
            lyricsContent.classList.toggle('hidden', !expanded);
            if (arrow) arrow.style.transform = expanded ? 'rotate(180deg)' : 'rotate(0deg)';
            if (toggleBtn) toggleBtn.setAttribute('aria-expanded', expanded ? 'true' : 'false');
        }
        function toggleEpisode(epItem) {
            const lyricsContent = epItem.querySelector('.lyrics-content');
            setEpisodeExpanded(epItem, lyricsContent.classList.contains('hidden'));
        }

        // Row click is a mouse convenience...
        document.querySelectorAll('[data-ep-row]').forEach(row => {
            row.addEventListener('click', () => {
                toggleEpisode(row.closest('.episode-item'));
            });
        });

        // ...the dedicated button is the keyboard-accessible control
        // (native <button> handles Enter/Space; stopPropagation avoids a
        // double toggle from the row handler).
        document.querySelectorAll('[data-ep-toggle]').forEach(btn => {
            btn.addEventListener('click', (e) => {
                e.stopPropagation();
                toggleEpisode(btn.closest('.episode-item'));
            });
        });

        // Play buttons
        document.querySelectorAll('[data-play-track]').forEach(btn => {
            btn.addEventListener('click', (e) => {
                e.stopPropagation();
                const track = JSON.parse(btn.dataset.playTrack);
                window.playTrack(track);
            });
        });

        // Toggle all lyrics in a range
        window.toggleAllLyrics = function(range) {
            const section = document.querySelector(`[data-range="${range}"]`);
            const episodes = section.querySelectorAll('.episode-item');
            const toggleBtn = section.querySelector(`[data-toggle-all="${range}"]`);

            const allHidden = Array.from(episodes).every(ep =>
                ep.querySelector('.lyrics-content').classList.contains('hidden')
            );

            episodes.forEach(ep => {
                setEpisodeExpanded(ep, allHidden);
            });

            toggleBtn.textContent = allHidden ? '[collapse]' : '[lyrics]';
        };
    });
</script>

<style>
    .lyrics-arrow {
        transition: transform 0.2s ease;
    }
</style>
