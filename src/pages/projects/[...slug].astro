---
import { getCollection, render } from "astro:content";
import MinimalLayout from "../../layouts/MinimalLayout.astro";
import githubProjects from "../../data/github-projects.json";
import "../../style/post.css"; // Standard typography

export async function getStaticPaths() {
    const projects = await getCollection("projects");
    return projects.map((entry) => ({
        params: { slug: entry.id },
        props: { entry },
    }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const readmes = await getCollection("projectReadmes");
const readme = readmes.find((item) => item.data.project === entry.id);
const ReadmeContent = readme ? (await render(readme)).Content : null;
const githubMeta = githubProjects.projects.find((item) => item.project === entry.id);

const ogImage =
    typeof entry.data.image === "string"
        ? entry.data.image
        : entry.data.image?.url;

const repoUrl = githubMeta?.url || (entry.data.githubRepo ? `https://github.com/${entry.data.githubRepo}` : "");
const repoLabel = entry.data.githubRepo || githubMeta?.repo;
const pushedDate = githubMeta?.pushedAt ? new Date(githubMeta.pushedAt) : null;
const syncedDate = readme?.data.syncedAt || null;

function compactDate(date: Date | null) {
    return date ? date.toISOString().split("T")[0].replace(/-/g, ".") : "—";
}
---

<MinimalLayout
    title={`${entry.data.title} | Projects`}
    description={entry.data.description}
    image={ogImage}
    ogType="article"
>
    <article
        class="p-6 md:p-12 max-w-4xl mx-auto anime-fade-in-up"
        transition:animate="fade"
    >
        <!-- Project Header -->
        <header class="mb-12 border-b border-[var(--border-main)] pb-8">
            <div
                class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-6"
            >
                <div>
                    <div
                        class="font-mono text-xs text-[var(--accent)] mb-2 uppercase tracking-wider"
                    >
                        {entry.data.type || "Project"} / {entry.data.status} / {
                            entry.data.pubDate.getFullYear()
                        }
                    </div>
                    <h1 class="text-4xl md:text-5xl font-bold font-heading">
                        {entry.data.title}
                    </h1>
                </div>

                <div class="flex flex-wrap gap-2">
                    {
                        entry.data.url && (
                            <a
                                href={entry.data.url}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="px-5 py-3 bg-[var(--text-main)] text-[var(--bg-body)] font-mono text-sm hover:opacity-80 transition-opacity"
                            >
                                [ Launch ] ↗
                            </a>
                        )
                    }
                    {
                        repoUrl && (
                            <a
                                href={repoUrl}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="px-5 py-3 border border-[var(--border-main)] font-mono text-sm hover:bg-[var(--text-main)] hover:text-[var(--bg-body)] transition-colors"
                            >
                                [ Source ] ↗
                            </a>
                        )
                    }
                </div>
            </div>

            <p
                class="text-xl text-[var(--text-muted)] leading-relaxed max-w-2xl"
            >
                {entry.data.description}
            </p>

            <!-- Tech Stack -->
            <div class="flex flex-wrap gap-2 mt-6">
                {
                    entry.data.stack.map((tech) => (
                        <span class="text-xs font-mono px-2 py-1 border border-[var(--border-main)] rounded-full text-[var(--text-muted)]">
                            {tech}
                        </span>
                    ))
                }
            </div>
        </header>

        {
            (repoLabel || githubMeta) && (
                <section class="mb-12 border border-[var(--border-main)]">
                    <div class="grid md:grid-cols-[10rem_minmax(0,1fr)] border-b border-[var(--border-main)]">
                        <div class="p-4 border-b md:border-b-0 md:border-r border-[var(--border-main)] font-mono text-xs uppercase tracking-wider text-[var(--text-muted)]">
                            GitHub
                        </div>
                        <div class="p-4 font-mono text-sm break-words">
                            {repoLabel}
                        </div>
                    </div>
                    <div class="grid grid-cols-2 md:grid-cols-4 text-sm font-mono">
                        <div class="p-4 border-r border-b md:border-b-0 border-[var(--border-main)]">
                            <div class="text-[10px] uppercase tracking-wider text-[var(--text-muted)] mb-1">
                                Language
                            </div>
                            <div>{githubMeta?.language || "—"}</div>
                        </div>
                        <div class="p-4 md:border-r border-b md:border-b-0 border-[var(--border-main)]">
                            <div class="text-[10px] uppercase tracking-wider text-[var(--text-muted)] mb-1">
                                Stars
                            </div>
                            <div>{githubMeta?.stars ?? "—"}</div>
                        </div>
                        <div class="p-4 border-r border-[var(--border-main)]">
                            <div class="text-[10px] uppercase tracking-wider text-[var(--text-muted)] mb-1">
                                Last Push
                            </div>
                            <div>{compactDate(pushedDate)}</div>
                        </div>
                        <div class="p-4">
                            <div class="text-[10px] uppercase tracking-wider text-[var(--text-muted)] mb-1">
                                README Sync
                            </div>
                            <div>{compactDate(syncedDate)}</div>
                        </div>
                    </div>
                    {
                        githubMeta?.description && (
                            <div class="p-4 border-t border-[var(--border-main)] text-sm text-[var(--text-muted)]">
                                {githubMeta.description}
                            </div>
                        )
                    }
                </section>
            )
        }

        <!-- Human-edited project brief -->
        <section class="mb-12">
            <div class="font-mono text-xs uppercase tracking-widest text-[var(--text-muted)] mb-6">
                [ Project Brief ]
            </div>
            <div class="post-content project-brief-content">
                <Content />
            </div>
        </section>

        {
            ReadmeContent && (
                <section class="mt-16 pt-10 border-t border-[var(--border-main)]">
                    <div class="flex flex-col md:flex-row md:items-end justify-between gap-2 mb-8">
                        <div>
                            <div class="font-mono text-xs uppercase tracking-widest text-[var(--text-muted)] mb-2">
                                [ Synced from GitHub README ]
                            </div>
                            <h2 class="text-2xl font-bold font-heading">
                                Repository Document
                            </h2>
                        </div>
                        {repoUrl && (
                            <a
                                href={repoUrl}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="font-mono text-xs text-[var(--text-muted)] hover:text-[var(--text-main)] underline underline-offset-4"
                            >
                                source ↗
                            </a>
                        )}
                    </div>
                    <div class="post-content github-readme-content">
                        <ReadmeContent />
                    </div>
                </section>
            )
        }
    </article>
</MinimalLayout>

<style>
    .project-brief-content :global(h1:first-child),
    .project-brief-content :global(h2:first-child),
    .github-readme-content :global(h1:first-child),
    .github-readme-content :global(h2:first-child) {
        margin-top: 0 !important;
    }
</style>
