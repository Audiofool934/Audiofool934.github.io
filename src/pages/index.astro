---
import MinimalLayout from "../layouts/MinimalLayout.astro";
import { formatDateCompact } from "../utils/formatDate";
import { getTimelineItems } from "../utils/timelineItems";

const timelinePosts = (await getTimelineItems()).slice(0, 3);
---

<MinimalLayout title="Audiofool — Creative AI, Notes, AudioShow & Photography">
	<div class="index-hero relative overflow-clip flex flex-col" transition:animate="fade">
		<!-- Background -->
		<div class="absolute bottom-0 right-0 pointer-events-none max-h-[50%] max-w-[66%] md:max-w-[50%]">
			<img
				src="/images/BG.webp"
				alt=""
				class="w-full h-full object-cover object-right-bottom opacity-50"
			/>
			<div class="absolute inset-0 bg-gradient-to-br from-[var(--bg-body)] via-transparent to-transparent"></div>
		</div>

		<!-- Content -->
		<div class="relative p-8 md:p-12 flex-1 flex flex-col justify-start pt-[15%] md:pt-[12%]">
			<h1
				class="flex items-center gap-4 md:gap-6 text-4xl md:text-6xl font-bold tracking-tight font-heading mb-12 md:mb-16"
			>
				<span>Audiofool</span>
				<img
					src="/images/audiofool-seal.webp"
					alt=""
					class="audiofool-seal h-11 w-11 md:h-14 md:w-14 shrink-0 opacity-90"
					aria-hidden="true"
				/>
			</h1>
			<div class="max-w-2xl text-[var(--text-muted)] text-base md:text-lg leading-relaxed space-y-5 index-intro">
				<p>
					I build and study <strong>creative AI</strong>, with a focus on
					<strong>multimodal understanding/generation</strong> and
					<strong>AI agent</strong>.
				</p>
				<p>
					The <a href="/timeline/">timeline</a> is a chronological trace of notes, projects, music, photos, and site changes. <a href="/projects/">Projects</a> collects what I’m building. <a href="/notes/">Notes</a> holds math, AI/ML, and ideas in progress. <a href="/audioshow/">AudioShow</a> is my long-running music journal — 200+ song episodes and curated listening crates. <a href="/gallery/">Gallery</a> keeps selected photographs I took.
				</p>
			</div>

			{
				timelinePosts.length > 0 && (
					<section class="mt-12 md:mt-16 max-w-3xl index-news">
						<div class="flex items-baseline gap-4 mb-3">
							<h2 class="font-mono text-xs uppercase tracking-widest text-[var(--text-muted)]">
								Updates
							</h2>
							<a
								href="/timeline/"
								class="font-mono text-xs text-[var(--text-muted)] hover:text-[var(--text-main)] transition-colors"
							>
								[ View timeline ]
							</a>
						</div>

						<div class="space-y-1.5">
							{timelinePosts.map((post) => {
								const type = post.lane;
								return (
									<a
										href={post.href}
										class="group block text-xs md:text-sm text-[var(--text-muted)] hover:text-[var(--text-main)] transition-colors"
									>
										<span class="font-mono uppercase tracking-wider text-[var(--text-faint)]">
											{formatDateCompact(post.date)} · {type}
										</span>
										<span class="mx-2 opacity-35">—</span>
										<span class="text-[var(--text-main)] group-hover:underline decoration-1 underline-offset-4">
											{post.title}
										</span>
									</a>
								);
							})}
						</div>
					</section>
				)
			}
		</div>
	</div>
</MinimalLayout>

<style>
	.index-hero {
		min-height: calc(100vh - 160px); /* mobile: nav + bottom player */
	}
	@media (min-width: 768px) {
		.index-hero {
			min-height: calc(100vh - 2rem);
		}
	}

	.audiofool-seal {
		border-radius: 9999px;
		filter: invert(1);
		image-rendering: auto;
	}

	:global(html.dark) .audiofool-seal {
		filter: none;
		opacity: 0.86;
	}

	.index-intro strong {
		color: var(--text-main);
		font-weight: 700;
	}

	.index-intro a {
		color: var(--text-main);
		text-decoration: underline;
		text-decoration-thickness: 1px;
		text-underline-offset: 3px;
		transition: all 0.2s ease;
	}
	.index-intro a:hover {
		background-color: var(--text-main);
		color: var(--bg-body);
		text-decoration: none;
	}
</style>
