---
import MinimalLayout from "../layouts/MinimalLayout.astro";
import { getCollection } from "astro:content";
import { formatDateCompact } from "../utils/formatDate";

const timelinePosts = (await getCollection("log"))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);

function getType(post: (typeof timelinePosts)[number]) {
	const tags = post.data.tags.map((tag) => tag.toLowerCase());
	if (tags.includes("photography") || tags.includes("gallery")) return "photo";
	if (
		tags.includes("notes") ||
		tags.includes("note") ||
		tags.includes("essay") ||
		tags.includes("math") ||
		tags.includes("dsp")
	) return "note";
	if (tags.includes("audioshow") || tags.includes("music")) return "music";
	if (tags.includes("project") || tags.includes("projects")) return "project";
	if (tags.includes("update") || tags.includes("meta")) return "site";
	return "post";
}
---

<MinimalLayout title="Audiofool">
	<div class="index-hero relative overflow-clip flex flex-col" transition:animate="fade">
		<!-- Background -->
		<div class="absolute bottom-0 right-0 pointer-events-none max-h-[50%] max-w-[66%] md:max-w-[50%]">
			<img
				src="/images/BG.webp"
				alt=""
				class="w-full h-full object-cover object-right-bottom opacity-50"
			/>
			<div class="absolute inset-0 bg-gradient-to-br from-[var(--bg-body)] via-transparent to-transparent"></div>
		</div>

		<!-- Content -->
		<div class="relative p-8 md:p-12 flex-1 flex flex-col justify-start pt-[15%] md:pt-[12%]">
			<h1
				class="flex items-center gap-4 md:gap-6 text-4xl md:text-6xl font-bold tracking-tight font-heading mb-12 md:mb-16"
			>
				<span>Audiofool</span>
				<img
					src="/images/audiofool-seal.png"
					alt=""
					class="audiofool-seal h-11 w-11 md:h-14 md:w-14 shrink-0 opacity-90"
					aria-hidden="true"
				/>
			</h1>
			<div class="max-w-2xl text-[var(--text-muted)] text-base md:text-lg leading-relaxed space-y-5 index-intro">
				<p>
					I build and study creative AI, with a focus on multimodal understanding/generation and agentic tools.
				</p>
				<p>
					The <a href="/timeline/">timeline</a> is a chronological trace of notes, projects, music, photos, and site changes. <a href="/projects/">Projects</a> collects what I’m building. <a href="/notes/">Notes</a> holds math, AI/ML, and ideas in progress. <a href="/audioshow/">AudioShow</a> is my long-running music journal — one song per episode, 200+ so far. <a href="/gallery/">Gallery</a> keeps selected photographs I took.
				</p>
			</div>

			{
				timelinePosts.length > 0 && (
					<section class="mt-12 md:mt-16 max-w-3xl index-news">
						<div class="flex items-baseline justify-between gap-4 border-b border-[var(--border-main)] pb-3 mb-5">
							<h2 class="font-mono text-xs uppercase tracking-widest text-[var(--text-muted)]">
								Updates
							</h2>
							<a
								href="/timeline/"
								class="font-mono text-xs text-[var(--text-muted)] hover:text-[var(--text-main)] transition-colors"
							>
								[ View timeline ]
							</a>
						</div>

						<div class="grid gap-3">
							{timelinePosts.map((post) => {
								const type = getType(post);
								return (
									<a
										href={`/timeline/${post.id}/`}
										class="group grid gap-2 border border-[var(--border-main)] p-4 text-[var(--text-muted)] hover:bg-[var(--text-main)] hover:text-[var(--bg-body)] transition-colors md:grid-cols-[6.5rem_minmax(0,1fr)] md:items-baseline"
									>
										<div class="flex items-center gap-3 font-mono text-[10px] uppercase tracking-wider opacity-55">
											<time>{formatDateCompact(post.data.pubDate)}</time>
											<span>{type}</span>
										</div>
										<div class="min-w-0">
											<h3 class="font-sans text-base font-semibold text-[var(--text-main)] group-hover:text-[var(--bg-body)]">
												{post.data.title}
											</h3>
											{post.data.description && (
												<p class="mt-1 text-sm leading-relaxed opacity-65">
													{post.data.description}
												</p>
											)}
										</div>
									</a>
								);
							})}
						</div>
					</section>
				)
			}
		</div>
	</div>
</MinimalLayout>

<style>
	.index-hero {
		min-height: calc(100vh - 160px); /* mobile: nav + bottom player */
	}
	@media (min-width: 768px) {
		.index-hero {
			min-height: calc(100vh - 2rem);
		}
	}

	.audiofool-seal {
		border-radius: 9999px;
		outline: 1px solid var(--border-main);
		filter: invert(1);
		image-rendering: auto;
	}

	:global(html.dark) .audiofool-seal {
		filter: none;
		opacity: 0.86;
	}

	.index-intro a {
		color: var(--text-main);
		text-decoration: underline;
		text-decoration-thickness: 1px;
		text-underline-offset: 3px;
		transition: all 0.2s ease;
	}
	.index-intro a:hover {
		background-color: var(--text-main);
		color: var(--bg-body);
		text-decoration: none;
	}
</style>
