---
import MinimalLayout from "../layouts/MinimalLayout.astro";
---

<MinimalLayout title="Audiofool">
	<div class="index-hero relative overflow-clip flex flex-col" transition:animate="fade">
		<!-- Background -->
		<div class="absolute bottom-0 right-0 pointer-events-none max-h-[50%] max-w-[66%] md:max-w-[50%]">
			<img
				src="/images/BG.webp"
				alt=""
				class="w-full h-full object-cover object-right-bottom opacity-50"
			/>
			<div class="absolute inset-0 bg-gradient-to-br from-[var(--bg-body)] via-transparent to-transparent"></div>
		</div>

		<!-- Content -->
		<div class="relative p-8 md:p-12 flex-1 flex flex-col justify-start pt-[15%] md:pt-[12%]">
			<h1
				class="flex items-center gap-4 md:gap-6 text-4xl md:text-6xl font-bold tracking-tight font-heading mb-12 md:mb-16"
			>
				<span>Audiofool</span>
				<img
					src="/images/audiofool-seal.png"
					alt=""
					class="audiofool-seal h-11 w-11 md:h-14 md:w-14 shrink-0 opacity-90"
					aria-hidden="true"
				/>
			</h1>
			<div class="max-w-2xl text-[var(--text-muted)] text-base md:text-lg leading-relaxed space-y-5 index-intro">
				<p>
					I build and study creative AI, with a focus on multimodal understanding/generation and agentic tools.
				</p>
				<p>
					The <a href="/timeline/">timeline</a> is the front door: a chronological trace of notes, projects, music, photos, and site changes. <a href="/projects/">Projects</a> collects the systems and research threads I am building. <a href="/notes/">Notes</a> holds probability, machine learning, DSP, and ideas in progress. <a href="/audioshow/">AudioShow</a> is my long-running music journal — one song per episode, 250+ so far. The <a href="/gallery/">gallery</a> keeps selected photographs, mostly from Beijing.
				</p>
			</div>
		</div>
	</div>
</MinimalLayout>

<style>
	.index-hero {
		min-height: calc(100vh - 160px); /* mobile: nav + bottom player */
	}
	@media (min-width: 768px) {
		.index-hero {
			min-height: calc(100vh - 2rem);
		}
	}

	.audiofool-seal {
		border-radius: 9999px;
		outline: 1px solid var(--border-main);
		filter: invert(1);
		image-rendering: auto;
	}

	:global(html.dark) .audiofool-seal {
		filter: none;
		opacity: 0.86;
	}

	.index-intro a {
		color: var(--text-main);
		text-decoration: underline;
		text-decoration-thickness: 1px;
		text-underline-offset: 3px;
		transition: all 0.2s ease;
	}
	.index-intro a:hover {
		background-color: var(--text-main);
		color: var(--bg-body);
		text-decoration: none;
	}
</style>
