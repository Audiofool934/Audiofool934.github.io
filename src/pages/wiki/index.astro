---
const target = "/notes/";
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="robots" content="noindex, follow" />
        <meta http-equiv="refresh" content={`0; url=${target}`} />
        <link rel="canonical" href={new URL(target, Astro.site).href} />
        <title>Notes | Audiofool</title>
    </head>
    <body>
        <p>This section is now <a href={target}>Notes</a>.</p>
    </body>
</html>
