---
import MinimalLayout from "../../layouts/MinimalLayout.astro";
import { getCollection } from "astro:content";

const wikiEntries = await getCollection("wiki");

// Sort by updatedDate desc (fallback to pubDate)
const sorted = [...wikiEntries].sort((a, b) => {
    const dateA = (
        a.data.updatedDate ||
        a.data.pubDate ||
        new Date(0)
    ).valueOf();
    const dateB = (
        b.data.updatedDate ||
        b.data.pubDate ||
        new Date(0)
    ).valueOf();
    return dateB - dateA;
});

// Entry lookup
const entryMap = new Map(sorted.map((e) => [e.id, e]));

// Bidirectional connection count
const connections = new Map<string, Set<string>>();
for (const entry of sorted) {
    if (!connections.has(entry.id)) connections.set(entry.id, new Set());
    for (const id of [
        ...(entry.data.parents || []),
        ...(entry.data.related || []),
    ]) {
        if (!entryMap.has(id)) continue;
        connections.get(entry.id)!.add(id);
        if (!connections.has(id)) connections.set(id, new Set());
        connections.get(id)!.add(entry.id);
    }
}

// Tag frequency (case-insensitive)
const tagFreq = new Map<string, number>();
const tagCanonical = new Map<string, string>();
for (const entry of sorted) {
    for (const tag of entry.data.tags) {
        const key = tag.toLowerCase();
        tagFreq.set(key, (tagFreq.get(key) || 0) + 1);
        if (!tagCanonical.has(key)) tagCanonical.set(key, tag);
    }
}
const filterTags = [...tagFreq.entries()]
    .filter(([, count]) => count >= 2)
    .sort((a, b) => b[1] - a[1])
    .map(([key, count]) => ({ key, label: tagCanonical.get(key)!, count }));

function getDate(entry: (typeof sorted)[0]) {
    const d = entry.data.updatedDate || entry.data.pubDate;
    return d ? d.toISOString().split("T")[0] : "";
}

function getConnectionCount(id: string) {
    return connections.get(id)?.size || 0;
}
---

<MinimalLayout title="Wiki | Audiofool" description="Knowledge Base">
    <div class="p-6 md:p-12 mb-20" transition:animate="fade">
        <header class="mb-8">
            <h1 class="text-4xl font-bold font-heading mb-2">Wiki</h1>
            <p
                class="font-mono text-sm text-[var(--text-muted)] tracking-wider uppercase"
            >
                {sorted.length} entries
            </p>
        </header>

        <!-- Tag Filters -->
        <div
            class="flex flex-wrap gap-3 pb-4 mb-8 border-b border-[var(--border-main)] text-sm font-mono"
        >
            <button
                data-tag="all"
                class="wiki-tag active whitespace-nowrap transition-colors"
            >
                [ All <span class="opacity-50">{sorted.length}</span> ]
            </button>
            {
                filterTags.map(({ key, label, count }) => (
                    <button
                        data-tag={key}
                        class="wiki-tag whitespace-nowrap transition-colors"
                    >
                        [ {label}{" "}
                        <span class="opacity-50">{count}</span> ]
                    </button>
                ))
            }
        </div>

        <!-- Entry List -->
        <div id="wiki-entries">
            {
                sorted.map((entry) => {
                    const connCount = getConnectionCount(entry.id);
                    const tagsLower = entry.data.tags.map((t) =>
                        t.toLowerCase(),
                    );
                    return (
                        <a
                            href={`/wiki/${entry.id}/`}
                            class="wiki-entry group block py-3.5 border-b border-[var(--border-subtle)] hover:border-[var(--border-main)] transition-colors"
                            data-tags={JSON.stringify(tagsLower)}
                        >
                            <div class="flex items-start justify-between gap-4">
                                <div class="min-w-0">
                                    <h3 class="font-bold text-[15px] group-hover:underline decoration-1 underline-offset-4">
                                        {entry.data.title}
                                    </h3>
                                    <div class="flex flex-wrap items-center gap-x-2 gap-y-1 mt-1.5">
                                        {entry.data.tags.map((tag) => (
                                            <span class="font-mono text-[10px] text-[var(--text-muted)] opacity-50">
                                                #{tag.toLowerCase()}
                                            </span>
                                        ))}
                                        {connCount > 0 && (
                                            <span class="font-mono text-[10px] text-[var(--text-muted)] opacity-30 ml-1">
                                                · {connCount}↔
                                            </span>
                                        )}
                                    </div>
                                </div>
                                <span class="flex-shrink-0 font-mono text-[11px] text-[var(--text-muted)] opacity-40 pt-0.5">
                                    {getDate(entry)}
                                </span>
                            </div>
                        </a>
                    );
                })
            }
        </div>

        {
            sorted.length === 0 && (
                <div class="py-16 text-center text-[var(--text-muted)]">
                    No entries yet.
                </div>
            )
        }
    </div>
</MinimalLayout>

<style>
    .wiki-tag {
        color: var(--text-muted);
    }
    .wiki-tag:hover {
        color: var(--text-main);
    }
    .wiki-tag.active {
        color: var(--text-main);
        text-decoration: underline;
        text-underline-offset: 4px;
        text-decoration-thickness: 1px;
    }
</style>

<script is:inline>
    (function () {
        let cleanupFn = null;

        document.addEventListener("astro:page-load", () => {
            if (cleanupFn) {
                cleanupFn();
                cleanupFn = null;
            }

            const tags = document.querySelectorAll(".wiki-tag");
            const entries = document.querySelectorAll(".wiki-entry");
            if (!tags.length) return;

            function applyFilter(filter) {
                tags.forEach((t) => t.classList.remove("active"));
                var btn = document.querySelector(
                    '.wiki-tag[data-tag="' + filter + '"]',
                );
                if (btn) btn.classList.add("active");

                entries.forEach((entry) => {
                    if (filter === "all") {
                        entry.style.display = "";
                    } else {
                        var entryTags = JSON.parse(entry.dataset.tags);
                        entry.style.display = entryTags.includes(filter)
                            ? ""
                            : "none";
                    }
                });
            }

            function onClick(e) {
                applyFilter(e.currentTarget.dataset.tag);
            }

            tags.forEach((tab) => {
                tab.addEventListener("click", onClick);
            });

            // Auto-filter from URL query
            var urlTag = new URLSearchParams(window.location.search).get("tag");
            if (urlTag) applyFilter(urlTag.toLowerCase());

            cleanupFn = function () {
                tags.forEach((t) => t.removeEventListener("click", onClick));
            };
        });
    })();
</script>
