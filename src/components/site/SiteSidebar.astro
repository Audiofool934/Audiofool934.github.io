---
import AudioPlayer from "../AudioPlayer.astro";

const NAV_ITEMS = [
    { label: "Timeline", href: "/timeline/" },
    { label: "Projects", href: "/projects/" },
    { label: "Notes", href: "/notes/" },
    { label: "AudioShow", href: "/audioshow/" },
    { label: "Gallery", href: "/gallery/" },
];
---

<aside class="w-full md:w-64 flex-shrink-0 border-b md:border-b-0 md:border-r border-[var(--border-main)] p-4 md:p-8 flex flex-col justify-between sticky top-0 md:h-screen transition-all z-[50] bg-[var(--bg-body)]">
    <div class="flex items-center justify-between md:hidden">
        <a href="/" class="text-xl font-bold font-mono tracking-tighter hover:opacity-60 transition-opacity">Audiofool</a>
        <div class="flex items-center gap-3">
            <button id="mobile-menu-toggle" aria-label="Toggle navigation menu" aria-expanded="false" aria-controls="nav-content" class="font-mono text-sm border border-[var(--border-main)] px-2 py-1 hover:bg-[var(--text-main)] hover:text-[var(--bg-body)] transition-colors">
                <span id="menu-icon">[ ≡ ]</span>
            </button>
            <button id="theme-toggle-mobile" aria-label="Toggle light/dark theme" class="text-xl hover:rotate-12 transition-transform" title="Toggle Theme">
                <span class="dark:hidden">🌑</span><span class="hidden dark:inline">🌕</span>
            </button>
        </div>
    </div>

    <div id="nav-content" class="hidden md:flex flex-col gap-8 mt-6 md:mt-0">
        <div class="hidden md:flex items-center justify-between">
            <a href="/" class="text-xl font-bold font-mono tracking-tighter hover:opacity-60 transition-opacity">Audiofool</a>
            <button id="theme-toggle" aria-label="Toggle light/dark theme" class="text-xl hover:rotate-12 transition-transform" title="Toggle Dark Side of the Moon">
                <span class="dark:hidden">🌑</span><span class="hidden dark:inline">🌕</span>
            </button>
        </div>

        <nav class="flex flex-col gap-4">
            {NAV_ITEMS.map((item) => (
                <a href={item.href} class="nav-link text-lg font-medium hover:underline underline-offset-4 decoration-1 decoration-[var(--border-main)]">[ {item.label} ]</a>
            ))}
            <div class="pt-6 mt-2 flex gap-4 border-t border-[var(--border-main)]">
                <a href="https://github.com/Audiofool934" target="_blank" rel="noopener noreferrer" class="text-[var(--text-muted)] hover:text-[var(--text-main)] transition-colors" title="GitHub" aria-label="GitHub profile">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"></path></svg>
                </a>
                <a href="https://x.com/Audiofool934" target="_blank" rel="noopener noreferrer" class="text-[var(--text-muted)] hover:text-[var(--text-main)] transition-colors" title="X" aria-label="X (Twitter) profile">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24h-6.654l-5.214-6.817-5.966 6.817H1.685l7.73-8.835L1.254 2.25H8.08l4.713 6.231 5.45-6.231Zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77Z"></path></svg>
                </a>
            </div>
        </nav>
    </div>

    <AudioPlayer />
</aside>
