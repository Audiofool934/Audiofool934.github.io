---
---

<div id="audio-player-bar" transition:persist>
    <!-- Hidden Audio Element (shared) -->
    <audio id="main-audio-element" preload="none"></audio>

    <!-- ==================== DESKTOP PLAYER (Sidebar) ==================== -->
    <div
        class="hidden md:flex flex-col gap-4 w-full bg-[var(--bg-body)] z-[100] transition-all duration-300 mt-auto"
    >
        <!-- Header -->
        <div class="flex items-center justify-between">
            <span
                class="text-[10px] font-mono uppercase tracking-widest text-[var(--text-muted)]"
                >Now Playing</span
            >
            <div class="flex items-center gap-2">
                <div
                    class="w-1.5 h-1.5 rounded-full bg-green-500 animate-pulse"
                >
                </div>
                <span class="text-[10px] font-mono text-[var(--text-muted)]"
                    >Online</span
                >
            </div>
        </div>

        <!-- Art -->
        <div
            id="player-art"
            class="w-full aspect-square bg-[var(--bg-body)] border border-[var(--border-main)] relative overflow-hidden group"
        >
            <img
                id="player-art-img"
                src=""
                alt=""
                width="320"
                height="320"
                loading="lazy"
                decoding="async"
                fetchpriority="low"
                class="absolute inset-0 w-full h-full object-cover opacity-0 transition-opacity duration-500"
            />
            <div
                id="player-art-placeholder"
                class="absolute inset-0 flex items-center justify-center font-mono text-2xl text-[var(--text-muted)]"
            >
                📻
            </div>
            <button
                id="player-art-btn"
                type="button"
                class="absolute inset-0 bg-black/50 opacity-0 group-hover:opacity-100 focus-visible:opacity-100 transition-opacity flex items-center justify-center cursor-pointer disabled:cursor-default disabled:opacity-0"
                aria-label="No track selected"
                disabled
            >
                <span class="text-white text-3xl opacity-80 hover:opacity-100"
                    >⏯</span
                >
            </button>
        </div>

        <!-- Track Info -->
        <div class="flex flex-col min-w-0" aria-live="polite" aria-atomic="true">
            <div
                id="player-track-name"
                class="text-sm font-bold truncate leading-tight"
            >
                Select a track...
            </div>
            <div
                id="player-artist-name"
                class="text-xs text-[var(--text-muted)] truncate mt-1"
            >
                AudioShow
            </div>
        </div>

        <!-- Controls & Progress -->
        <div class="flex flex-col gap-3 w-full">
            <div
                class="w-full h-1 bg-[var(--text-muted)]/30 relative group cursor-pointer"
                id="player-seek-container"
                role="slider"
                tabindex="0"
                aria-label="Seek"
                aria-valuemin="0"
                aria-valuemax="100"
                aria-valuenow="0"
            >
                <div
                    id="player-progress-bar"
                    class="absolute top-0 left-0 h-full bg-[var(--text-main)] w-0"
                >
                </div>
                <div
                    class="absolute -top-2 -bottom-2 left-0 right-0 bg-transparent"
                >
                </div>
            </div>
            <div
                class="flex items-center justify-between text-[10px] font-mono text-[var(--text-muted)]"
            >
                <span id="player-current-time">0:00</span>
                <div class="flex items-center gap-2">
                    <button
                        id="player-shuffle-btn"
                        aria-label="Shuffle"
                        aria-pressed="false"
                        class="hover:text-[var(--text-main)] transition-colors p-1"
                        title="Shuffle"
                    >
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="16 3 21 3 21 8" />
                            <line x1="4" y1="20" x2="21" y2="3" />
                            <polyline points="21 16 21 21 16 21" />
                            <line x1="15" y1="15" x2="21" y2="21" />
                            <line x1="4" y1="4" x2="9" y2="9" />
                        </svg>
                    </button>
                    <button
                        id="player-prev-btn"
                        aria-label="Previous track"
                        class="hover:text-[var(--text-main)] transition-colors p-1"
                        title="Previous"
                    >
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <polygon points="19 20 9 12 19 4" />
                            <line x1="5" y1="19" x2="5" y2="5" />
                        </svg>
                    </button>
                    <button
                        id="player-play-btn"
                        aria-label="Play"
                        class="hover:text-[var(--text-main)] transition-colors disabled:opacity-30 p-1"
                        disabled
                    >
                        <span id="play-icon" class="text-xl">▶</span>
                    </button>
                    <button
                        id="player-next-btn"
                        aria-label="Next track"
                        class="hover:text-[var(--text-main)] transition-colors p-1"
                        title="Next"
                    >
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <polygon points="5 4 15 12 5 20" />
                            <line x1="19" y1="5" x2="19" y2="19" />
                        </svg>
                    </button>
                </div>
                <span id="player-duration">0:00</span>
            </div>
        </div>
    </div>

    <!-- ==================== MOBILE PLAYER (Fixed Bottom Bar) ==================== -->
    <div
        class="md:hidden fixed bottom-0 left-0 right-0 bg-[var(--bg-body)] border-t border-[var(--border-main)] z-[200] px-4 pt-3 safe-area-inset-bottom"
    >
        <div class="flex items-center gap-1">
            <!-- Mini Artwork -->
            <div
                class="w-12 h-12 flex-shrink-0 border border-[var(--border-main)] relative overflow-hidden bg-[var(--bg-body)]"
            >
                <img
                    id="player-art-img-mobile"
                    src=""
                    alt=""
                    width="48"
                    height="48"
                    loading="lazy"
                    decoding="async"
                    fetchpriority="low"
                    class="absolute inset-0 w-full h-full object-cover opacity-0 transition-opacity duration-300"
                />
                <div
                    id="player-art-placeholder-mobile"
                    class="absolute inset-0 flex items-center justify-center font-mono text-lg text-[var(--text-muted)]"
                >
                    📻
                </div>
            </div>

            <!-- Track Info -->
            <div class="flex-1 min-w-0 px-1" aria-live="polite" aria-atomic="true">
                <div
                    id="player-track-name-mobile"
                    class="text-sm font-bold truncate"
                >
                    Select a track...
                </div>
                <div
                    id="player-artist-name-mobile"
                    class="text-xs text-[var(--text-muted)] truncate"
                >
                    AudioShow
                </div>
            </div>

            <!-- Controls -->
            <button
                id="player-shuffle-btn-mobile"
                aria-label="Shuffle"
                aria-pressed="false"
                class="w-11 h-11 flex items-center justify-center text-[var(--text-muted)] hover:text-[var(--text-main)] transition-colors"
                title="Shuffle"
            >
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="16 3 21 3 21 8" />
                    <line x1="4" y1="20" x2="21" y2="3" />
                    <polyline points="21 16 21 21 16 21" />
                    <line x1="15" y1="15" x2="21" y2="21" />
                    <line x1="4" y1="4" x2="9" y2="9" />
                </svg>
            </button>
            <button
                id="player-prev-btn-mobile"
                aria-label="Previous track"
                class="w-11 h-11 flex items-center justify-center text-[var(--text-muted)] hover:text-[var(--text-main)] transition-colors"
                title="Previous"
            >
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polygon points="19 20 9 12 19 4" />
                    <line x1="5" y1="19" x2="5" y2="5" />
                </svg>
            </button>
            <button
                id="player-play-btn-mobile"
                aria-label="Play"
                class="w-11 h-11 flex items-center justify-center border border-[var(--border-main)] hover:bg-[var(--text-main)] hover:text-[var(--bg-body)] transition-colors disabled:opacity-30"
                disabled
            >
                <span id="play-icon-mobile" class="text-lg">▶</span>
            </button>
            <button
                id="player-next-btn-mobile"
                aria-label="Next track"
                class="w-11 h-11 flex items-center justify-center text-[var(--text-muted)] hover:text-[var(--text-main)] transition-colors"
                title="Next"
            >
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polygon points="5 4 15 12 5 20" />
                    <line x1="19" y1="5" x2="19" y2="19" />
                </svg>
            </button>
        </div>

        <!-- Mini Progress Bar -->
        <div class="w-full h-0.5 bg-[var(--text-muted)]/20 mt-2 -mb-1">
            <div
                id="player-progress-bar-mobile"
                class="h-full bg-[var(--text-main)] w-0 transition-all"
            >
            </div>
        </div>
    </div>
</div>

<script is:inline>
    window.__audioPlayerConfig = {
        playlistUrl: "/audioshow/playlist.json",
    };
</script>

<script>
    import "../scripts/audioPlayer.ts";
</script>

<style>
    #player-play-btn span {
        font-family: system-ui, sans-serif;
        font-size: 14px;
        font-weight: bold;
    }
    #player-seek-container:hover #player-progress-bar {
        background: var(--text-muted);
    }
</style>
