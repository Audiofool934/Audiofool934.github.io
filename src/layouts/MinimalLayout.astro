---
import "../style/global.css";
import "../style/prism-theme.css";
import SiteHead from "../components/site/SiteHead.astro";
import SiteSidebar from "../components/site/SiteSidebar.astro";
import SiteThemeScripts from "../components/site/SiteThemeScripts.astro";
import { getDefaultAudioTrack } from "../utils/defaultAudioTrack";

interface Props {
    title: string;
    description?: string;
    lang?: string;
    image?: string;
    imageAlt?: string;
    ogType?: string;
    math?: boolean;
    datePublished?: Date;
    dateModified?: Date;
}

const {
    title,
    imageAlt = title,
    description = "Audiofool — creative AI, notes, an AudioShow music journal, and photography.",
    lang = "en",
    image = "/images/audiofool-seal.png",
    ogType = "website",
    math = false,
    datePublished,
    dateModified,
} = Astro.props;

const defaultTrackData = getDefaultAudioTrack();
---

<!doctype html>
<html lang={lang} class="scroll-smooth dark">
    <head>
        <SiteHead
            title={title}
            description={description}
            image={image}
            imageAlt={imageAlt}
            ogType={ogType}
            math={math}
            datePublished={datePublished}
            dateModified={dateModified}
        />
        <SiteThemeScripts />
    </head>
    <body class="min-h-screen flex flex-col font-sans bg-[var(--bg-body)] text-[var(--text-main)] transition-colors duration-300">
        <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-3 focus:left-3 focus:z-[300] focus:bg-[var(--bg-body)] focus:text-[var(--text-main)] focus:border focus:border-[var(--border-main)] focus:px-3 focus:py-2 focus:font-mono focus:text-sm">
            Skip to content
        </a>
        <div class="min-h-screen flex flex-col md:flex-row max-w-[1440px] mx-auto w-full border-x border-[var(--border-main)] pb-20 md:pb-0">
            <SiteSidebar />
            <main id="main-content" tabindex="-1" class="flex-1 min-w-0 w-full outline-none">
                <slot />
            </main>
        </div>

        <script is:inline>
            function applyTheme() {
                const html = document.documentElement;
                const theme = localStorage.getItem("theme");
                if (theme === "light") {
                    html.classList.remove("dark");
                } else {
                    html.classList.add("dark");
                }
            }

            function attachToggle() {
                const themeToggle = document.getElementById("theme-toggle");
                const themeToggleMobile = document.getElementById("theme-toggle-mobile");
                const menuToggle = document.getElementById("mobile-menu-toggle");
                const menuIcon = document.getElementById("menu-icon");
                const navContent = document.getElementById("nav-content");
                const html = document.documentElement;

                const toggleTheme = () => {
                    const nextTheme = html.classList.contains("dark") ? "light" : "dark";
                    localStorage.setItem("theme", nextTheme);
                    applyTheme();
                };

                if (themeToggle) themeToggle.onclick = toggleTheme;
                if (themeToggleMobile) themeToggleMobile.onclick = toggleTheme;

                if (menuToggle && navContent && menuIcon) {
                    const closeMenu = () => {
                        navContent.classList.add("hidden");
                        navContent.classList.remove("flex");
                        menuIcon.textContent = "[ ≡ ]";
                        menuToggle.setAttribute("aria-expanded", "false");
                    };
                    menuToggle.onclick = () => {
                        const isHidden = navContent.classList.contains("hidden");
                        if (isHidden) {
                            navContent.classList.remove("hidden");
                            navContent.classList.add("flex");
                            menuIcon.textContent = "[ × ]";
                            menuToggle.setAttribute("aria-expanded", "true");
                        } else {
                            closeMenu();
                        }
                    };
                    navContent.querySelectorAll(".nav-link").forEach((link) => {
                        link.addEventListener("click", closeMenu);
                    });
                }
            }

            function focusMain() {
                const main = document.getElementById("main-content");
                if (main) main.focus({ preventScroll: true });
            }

            document.addEventListener("astro:after-swap", applyTheme);
            document.addEventListener("astro:after-swap", focusMain);
            document.addEventListener("astro:page-load", attachToggle);
        </script>

        <script is:inline define:vars={{ defaultTrackData }}>
            if (defaultTrackData) {
                window.__defaultAudioShowTrack = defaultTrackData;
            }
        </script>
    </body>
</html>
